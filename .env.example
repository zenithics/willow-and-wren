# Database
DATABASE_URI=postgresql://user:password@host:5432/dbname
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# Payload
PAYLOAD_SECRET=your-random-secret-here-change-in-production
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Live Preview
PREVIEW_SECRET=any-random-string

# Vercel Blob Storage (for media uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Email (optional — for contact forms, newsletters)
RESEND_API_KEY=re_...

# Cron Jobs (optional)
CRON_SECRET=your-cron-secret

# IndexNow (optional — for search engine indexing)
INDEXNOW_API_KEY=your-indexnow-key
